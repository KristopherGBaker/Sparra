{
  "name": "sparra",
  "version": "0.1.0",
  "description": "A long-running autonomous build harness on the Claude Agent SDK: plan collaboratively, optionally prototype, then hand off to an adversarial generator/evaluator build loop. Works on greenfield and existing codebases.",
  "type": "module",
  "license": "MIT",
  "author": "Kristopher Baker <hello@krisbaker.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KristopherGBaker/Sparra.git"
  },
  "homepage": "https://github.com/KristopherGBaker/Sparra#readme",
  "bugs": {
    "url": "https://github.com/KristopherGBaker/Sparra/issues"
  },
  "bin": {
    "sparra": "./bin/sparra.mjs",
    "sparra-run-mcp": "./bin/sparra-run-mcp.mjs"
  },
  "scripts": {
    "sparra": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.206",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "@openai/codex-sdk": "^0.144.1"
  }
}

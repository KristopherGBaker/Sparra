<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template LaunchAgent for the Sparra HTTP bridge. Every value below is a FAKE placeholder that the
  setup script fills in automatically — you do NOT hand-edit this file. `make bridge-install` (or
  `node bin/sparra-bridge-setup.mjs install`) renders a real plist from this template with your node
  path, this checkout's bin/working-directory, `~/Library/Logs` log paths, `~/.sparra/bridge.yaml`,
  and a freshly generated crypto-random Bearer token; it then writes the rendered plist (mode 0600)
  to ~/Library/LaunchAgents and loads it via launchctl, printing the token to you ONCE. A re-install
  preserves the existing token (pass `--rotate-token` to change it). After rendering, the setup guard
  refuses to write if any placeholder below survived (i.e. the template grew a field the renderer
  doesn't fill yet).

  See conductors/http/README.md for the full walkthrough (bridge.yaml, uninstall; make
  bridge-update / bridge-status / bridge-logs / bridge-remove cover the rest of the lifecycle).
-->
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.sparra.bridge</string>

	<!-- Start on login, and relaunch it whenever it exits (crash or `kill`) — this is meant to be a
	     long-running background service, not a one-shot job. -->
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>

	<!-- node + this checkout's `sparra-bridge` bin. The setup script fills these with the running
	     node (`process.execPath`) and the absolute `bin/sparra-bridge.mjs` path in this checkout. -->
	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/node</string>
		<string>/Users/example/code/Sparra/bin/sparra-bridge.mjs</string>
	</array>

	<!-- The Sparra checkout the bridge serves from. The setup script fills this with this checkout. -->
	<key>WorkingDirectory</key>
	<string>/Users/example/code/Sparra</string>

	<key>EnvironmentVariables</key>
	<dict>
		<!-- REQUIRED. A long random secret the bridge compares (constant-time) against every
		     request's `Authorization: Bearer <token>` header. The setup script fills this with a
		     freshly generated `crypto.randomBytes(32)` hex token (the placeholder below is never a
		     real secret) and prints it to you once. -->
		<key>SPARRA_BRIDGE_TOKEN</key>
		<string>REPLACE_WITH_A_LONG_RANDOM_SECRET_TOKEN</string>

		<!-- launchd starts services with a bare PATH (/usr/bin:/bin:/usr/sbin:/sbin) that omits your
		     node install (e.g. nvm/Homebrew). The bridge re-execs `tsx` via a `#!/usr/bin/env node`
		     shebang, so without node on PATH the service crash-loops with `env: node: No such file`.
		     The setup script fills this with the running node's bin directory prepended to the
		     system PATH. -->
		<key>PATH</key>
		<string>REPLACE_WITH_NODE_BIN_PATH</string>

		<!-- Path to your bridge.yaml (see conductors/http/bridge.yaml.example). The setup script
		     fills this with ~/.sparra/bridge.yaml. -->
		<key>SPARRA_BRIDGE_CONFIG</key>
		<string>/Users/example/.sparra/bridge.yaml</string>

		<!-- Whatever agent backend(s) the triggered `sparra` roles use must be authenticated in THIS
		     environment too — launchd agents don't inherit your interactive shell's login state.
		     Supply an Anthropic credential (an ANTHROPIC_API_KEY, or a machine-wide Claude Code
		     login) and/or Codex auth (a `~/.codex` login this launchd user can read) here, or the
		     triggered `sparra build`/`role run` calls will fail to authenticate. To add one, insert a
		     real key/string pair here after install (it is not part of the auto-rendered template). -->
		<!-- <key>ANTHROPIC_API_KEY</key> -->
		<!-- <string>your-anthropic-key-or-omit-and-use-a-claude-code-login</string> -->
	</dict>

	<!-- Log paths — the setup script fills these with ~/Library/Logs/sparra-bridge{.log,.err.log}. -->
	<key>StandardOutPath</key>
	<string>/Users/example/Library/Logs/sparra-bridge.log</string>
	<key>StandardErrorPath</key>
	<string>/Users/example/Library/Logs/sparra-bridge.err.log</string>
</dict>
</plist>
